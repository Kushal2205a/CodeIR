{
  "name": "learntovibe",
  "displayName": "learntovibe",
  "description": "Learn and reconstruct code functions",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:go"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "learntovibe.learnFunction",
        "title": "Learn this function",
        "category": "LearnToVibe"
      },
      {
        "command": "learntovibe.practiceFunction",
        "title": "Practice this function",
        "category": "LearnToVibe"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "learntovibe.learnFunction",
          "when": "editorLangId in learntovibe.supportedLanguages",
          "group": "learntovibe@1"
        },
        {
          "command": "learntovibe.practiceFunction",
          "when": "editorLangId in learntovibe.supportedLanguages",
          "group": "learntovibe@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "learntovibe.learnFunction",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "learntovibe.practiceFunction",
        "key": "ctrl+shift+p",
        "mac": "cmd+shift+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "LearnToVibe",
      "properties": {
        "learntovibe.apiProvider": {
          "type": "string",
          "enum": [
            "nvidia",
            "ollama"
          ],
          "default": "nvidia",
          "description": "AI provider to use for explanations and practice generation."
        },
        "learntovibe.nvidiaApiKey": {
          "type": "string",
          "default": "",
          "description": "Your NVIDIA API key for Kimi K2.6."
        },
        "learntovibe.ollamaBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL for your Ollama instance."
        },
        "learntovibe.ollamaModel": {
          "type": "string",
          "default": "llama3",
          "description": "Ollama model name to use (e.g. llama3, mistral, codellama)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}