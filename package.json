{
  "name": "learntovibe",
  "displayName": "learntovibe",
  "description": "Learn and reconstruct code functions",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:python",
    "onLanguage:go"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "learntovibe.learnFunction",
        "title": "Learn this function",
        "category": "LearnToVibe"
      },
      {
        "command": "learntovibe.practiceFunction",
        "title": "Practice this function",
        "category": "LearnToVibe"
      },
      {
        "command": "learntovibe.setApiKey",
        "title": "Set API Key",
        "category": "LearnToVibe"
      },
      {
        "command": "learntovibe.clearApiKey",
        "title": "Clear API Key",
        "category": "LearnToVibe"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "learntovibe.learnFunction",
          "when": "editorLangId in learntovibe.supportedLanguages",
          "group": "learntovibe@1"
        },
        {
          "command": "learntovibe.practiceFunction",
          "when": "editorLangId in learntovibe.supportedLanguages",
          "group": "learntovibe@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "learntovibe.learnFunction",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus"
      },
      {
        "command": "learntovibe.practiceFunction",
        "key": "ctrl+shift+alt+p",
        "mac": "cmd+shift+alt+p",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "LearnToVibe",
      "properties": {
        "learntovibe.apiProvider": {
          "type": "string",
          "enum": [
            "nvidia",
            "openai",
            "anthropic",
            "ollama"
          ],
          "default": "nvidia",
          "markdownDescription": "Primary AI provider for explanations and practice generation. Choose **NVIDIA** (cloud, free tier), **OpenAI** (GPT-4o), **Anthropic** (Claude), or **Ollama** (local).",
          "enumDescriptions": [
            "NVIDIA AI (cloud, default: Kimi K2.6)",
            "OpenAI (GPT-4o, GPT-4o-mini)",
            "Anthropic (Claude Sonnet)",
            "Ollama (local models via localhost)"
          ],
          "order": 1
        },
        "learntovibe.nvidia.model": {
          "type": "string",
          "default": "moonshotai/kimi-k2.6",
          "markdownDescription": "NVIDIA model ID to use. Find models at [catalog.ngc.nvidia.com](https://catalog.ngc.nvidia.com).",
          "order": 2
        },
        "learntovibe.openai.model": {
          "type": "string",
          "default": "gpt-4o",
          "markdownDescription": "OpenAI model ID. Use `gpt-4o` for best quality, `gpt-4o-mini` for speed/cost.",
          "order": 3
        },
        "learntovibe.anthropic.model": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "markdownDescription": "Anthropic model ID. Use `claude-sonnet-4-20250514` (latest, high quality) or `claude-3-5-sonnet-20240620` (stable).",
          "order": 4
        },
        "learntovibe.ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "markdownDescription": "Base URL for your local Ollama instance.",
          "order": 5
        },
        "learntovibe.ollama.model": {
          "type": "string",
          "default": "llama3.1",
          "markdownDescription": "Ollama model name. Examples: `llama3.1`, `deepseek-coder-v2`, `mistral`, `qwen2.5`. Run `ollama list` to see installed models.",
          "order": 6
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.19",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.21.0",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-typescript": "^0.23.2"
  }
}